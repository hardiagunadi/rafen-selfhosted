APP_NAME="Rafen Self-Hosted"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rafen_selfhosted
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file

LICENSE_SELF_HOSTED_ENABLED=true
LICENSE_ENFORCE=true
LICENSE_PUBLIC_KEY=
LICENSE_FILE_PATH=storage/app/license/rafen.lic
LICENSE_MACHINE_ID_PATH=/etc/machine-id
LICENSE_DEFAULT_GRACE_DAYS=21

GENIEACS_NBI_URL=http://127.0.0.1:7557
GENIEACS_UI_URL=http://127.0.0.1:3000
GENIEACS_NBI_USERNAME=
GENIEACS_NBI_PASSWORD=
GENIEACS_NBI_TIMEOUT=10
GENIEACS_LOG_PATH=storage/logs/genieacs.log
GENIEACS_CWMP_STATUS_COMMAND="systemctl is-active genieacs-cwmp"
GENIEACS_CWMP_RESTART_COMMAND="systemctl restart genieacs-cwmp"
GENIEACS_NBI_STATUS_COMMAND="systemctl is-active genieacs-nbi"
GENIEACS_NBI_RESTART_COMMAND="systemctl restart genieacs-nbi"
GENIEACS_FS_STATUS_COMMAND="systemctl is-active genieacs-fs"
GENIEACS_FS_RESTART_COMMAND="systemctl restart genieacs-fs"

WG_HOST=localhost
WG_SERVER_IP=10.0.0.1
WG_SERVER_ADDRESS=10.0.0.1/24
WG_LISTEN_PORT=51820
WG_INTERFACE=wg0
WG_CONFIG_PATH=storage/app/wireguard/wg0.conf
WG_SERVER_PRIVATE_KEY_PATH=storage/app/wireguard/server_private.key
WG_SERVER_PUBLIC_KEY_PATH=storage/app/wireguard/server_public.key
WG_POOL_START=10.0.0.2
WG_POOL_END=10.0.0.254
